<?xml version="1.0" encoding="UTF-8"?>

<launch>

  <arg name="database_path" default="$(find my_robot)/launch/rtabmap.db"/>
  <arg name="rgb_topic" default="/camera/rgb/image_raw"/>
  <arg name="depth_topic" default="/camera/depth/image_raw"/>
  <arg name="camera_info_topic" default="/camera/rgb/camera_info"/>

  <node name="rtabmap"
        pkg="rtabmap_slam"
        type="rtabmap"
        output="screen"
        args="--delete_db_on_start">

    <param name="database_path" value="$(arg database_path)"/>
    <param name="frame_id" value="robot_footprint"/>
    <param name="odom_frame_id" value="odom"/>

    <param name="subscribe_rgb" value="true"/>
    <param name="subscribe_depth" value="true"/>
    <param name="subscribe_scan" value="true"/>

    <param name="approx_sync" value="true"/>
    <param name="queue_size" value="30"/>
    <param name="topic_queue_size" value="30"/>
    <param name="sync_queue_size" value="30"/>

    <remap from="odom" to="/odom"/>
    <remap from="scan" to="/scan"/>
    <remap from="rgb/image" to="$(arg rgb_topic)"/>
    <remap from="depth/image" to="$(arg depth_topic)"/>
    <remap from="rgb/camera_info" to="$(arg camera_info_topic)"/>
    <remap from="grid_map" to="/map"/>

    <param name="Rtabmap/DetectionRate" value="1"/>
    <param name="Reg/Force3DoF" value="true"/>
    <param name="Kp/DetectorStrategy" value="0"/>
    <param name="Kp/MaxFeatures" value="400"/>
    <param name="SURF/HessianThreshold" value="100"/>
    <param name="Reg/Strategy" value="0"/>
    <param name="Vis/MinInliers" value="15"/>
    <param name="Mem/IncrementalMemory" type="string" value="true"/>
    <param name="Mem/NotLinkedNodesKept" type="string" value="false"/>
  </node>

  <node pkg="rtabmap_viz"
        type="rtabmap_viz"
        name="rtabmapviz"
        output="screen">

    <param name="subscribe_rgb" value="true"/>
    <param name="subscribe_depth" value="true"/>
    <param name="subscribe_scan" value="true"/>
    <param name="frame_id" value="robot_footprint"/>

    <param name="approx_sync" value="true"/>
    <param name="queue_size" value="30"/>
    <param name="topic_queue_size" value="30"/>
    <param name="sync_queue_size" value="30"/>

    <remap from="odom" to="/odom"/>
    <remap from="scan" to="/scan"/>
    <remap from="depth/image"     to="$(arg depth_topic)"/>
    <remap from="rgb/image" to="$(arg rgb_topic)"/>
    <remap from="rgb/camera_info" to="$(arg camera_info_topic)"/>
  </node>

</launch>
